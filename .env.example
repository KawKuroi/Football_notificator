# Cuenta Gmail desde la que se envían los correos.
# Requiere 2FA + contraseña de aplicación (https://myaccount.google.com/apppasswords).
GMAIL_USER=tu_correo@gmail.com
GMAIL_PASSWORD=xxxx xxxx xxxx xxxx

# Necesario en Windows para que los emojis del log no causen UnicodeEncodeError.
# En Docker/Linux no tiene efecto.
PYTHONUTF8=1
